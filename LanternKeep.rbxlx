		</Properties>
		<Item class="Folder" referent="3">
			<Properties>
				<BinaryString name="AttributesSerialize"></BinaryString>
				<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
				<bool name="DefinesCapabilities">false</bool>
				<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
				<string name="Name">Shared</string>
				<int64 name="SourceAssetId">-1</int64>
				<BinaryString name="Tags"></BinaryString>
				<UniqueId name="UniqueId">4be6c94ec416c0c409e3a3080000039c</UniqueId>
			</Properties>
			<Item class="ModuleScript" referent="4">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[local GameConfig = table.freeze({
	MinimumPlayers = 1,
	MaximumPlayers = 12,
	PhaseDurations = table.freeze({
		Lobby = 20,
		DayPrep = 90,
		NightSurvival = 120,
		Results = 20,
	}),
	TutorialTuning = table.freeze({
		GuidedRounds = 1,
		Title = "First Watch",
		Summary = "A shorter guided watch that teaches fuel, roles, rites, and lane defense.",
		DayPrepDuration = 65,
		NightSurvivalDuration = 75,
		ResourceNodes = 4,
		TargetBarricadeLaneName = "East",
		TargetTowerLaneName = "North",
		AllowedLaneNames = table.freeze({ "North", "East" }),
		ForcedLaneSequence = table.freeze({ "North", "East", "North", "East", "North", "East" }),
		ThreatSequence = table.freeze({ "Runner", "Runner", "Runner", "Runner", "Brute", "Runner" }),
		SpawnIntervalSeconds = 7,
		MaxSimultaneousThreats = 2,
		WarningLeadSeconds = 1.8,
		ThreatRate = 1.1,
	}),
	RewardTuning = table.freeze({
		BaseCoins = 20,
		BaseExperience = 15,
		ObjectiveCoins = 12,
		ObjectiveExperience = 10,
		SurvivalBonusMultiplier = 1.4,
		LanternChargeBonus = 10,
		BarricadeHoldCoins = 3,
		FortificationCoins = 4,
		OverchargeCoins = 3,
		SupplySpendCoins = 2,
		NightClearCoins = 12,
		NightClearExperience = 10,
		TeamCoverageCoins = 5,
		ConcordLaneCoins = 6,
		ReviveCoins = 8,
		ReviveExperience = 6,
	}),
	SpawnTuning = table.freeze({
		BaseThreatRate = 1,
		AdditionalThreatPerPlayer = 0.18,
		NightGrowth = 0.35,
