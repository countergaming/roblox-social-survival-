						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">RemoteSetup</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">4be6c94ec416c0c409e3a308000003ab</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="20">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = ReplicatedStorage:WaitForChild("Shared")
local GameConfig = require(Shared:WaitForChild("GameConfig"))
local RemoteNames = require(Shared:WaitForChild("RemoteNames"))

local RescueService = {}

local objectiveService = nil
local currentNightToken = 0
local refreshLoopToken = 0
local downedEntriesByUserId = {}
local activeSurge = nil
local rescueState = table.freeze({
	phaseName = "Lobby",
	roundNumber = 0,
	activeDownedCount = 0,
	totalRevives = 0,
	totalBleedouts = 0,
	activeSurgeLaneName = "",
	activeSurgeRemainingSeconds = 0,
	activeSurgeReviverName = "",
	activeSurgeRescuedName = "",
	downedPlayers = table.freeze({}),
})
local totalRevives = 0
local totalBleedouts = 0

local EMPTY_LANE_MODIFIERS = table.freeze({
	towerDamageBonus = 0,
	towerRangeBonus = 0,
	barricadeMitigationBonus = 0,
})

local EMPTY_COMBAT_MODIFIERS = table.freeze({
	meleeDamageBonus = 0,
	pulseDamageBonus = 0,
	pulseCooldownDelta = 0,
})

local function getRemoteEvent(): RemoteEvent
	local remoteFolder = ReplicatedStorage:WaitForChild(RemoteNames.Folder)
	return remoteFolder:WaitForChild(RemoteNames.RescueStateChanged) :: RemoteEvent
end

local function getCharacterState(player: Player)
	local character = player.Character

	if character == nil then
		return nil, nil, nil
	end

	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local rootPart = character:FindFirstChild("HumanoidRootPart")

	return character, humanoid, rootPart
end

local function getRemainingBleedoutSeconds(entry): number
	return math.max(0, math.ceil(entry.bleedoutEndsAt - os.clock()))
end

local function getActiveSurgeRemainingSeconds(): number
	if activeSurge == nil then
		return 0
	end

	return math.max(0, math.ceil(activeSurge.endsAt - os.clock()))
end

local function buildDownedSnapshots()
	local snapshots = {}

	for userId, entry in pairs(downedEntriesByUserId) do
		local player = Players:GetPlayerByUserId(userId)

		if player ~= nil then
			table.insert(snapshots, {
				userId = userId,
				name = player.Name,
				displayName = player.DisplayName,
				laneName = entry.laneName,
				bleedoutRemainingSeconds = getRemainingBleedoutSeconds(entry),
			})
		end
	end

	table.sort(snapshots, function(left, right)
		if left.bleedoutRemainingSeconds == right.bleedoutRemainingSeconds then
			return left.displayName < right.displayName
		end

		return left.bleedoutRemainingSeconds < right.bleedoutRemainingSeconds
	end)

	local frozenSnapshots = {}

	for _, snapshot in ipairs(snapshots) do
		table.insert(frozenSnapshots, table.freeze(snapshot))
	end

	return table.freeze(frozenSnapshots)
end

local function rebuildState(phaseName: string, roundNumber: number)
	if activeSurge ~= nil and activeSurge.endsAt <= os.clock() then
		activeSurge = nil
	end

	rescueState = table.freeze({
		phaseName = phaseName,
		roundNumber = roundNumber,
		activeDownedCount = #buildDownedSnapshots(),
		totalRevives = totalRevives,
		totalBleedouts = totalBleedouts,
		activeSurgeLaneName = if activeSurge ~= nil then activeSurge.laneName else "",
		activeSurgeRemainingSeconds = getActiveSurgeRemainingSeconds(),
		activeSurgeReviverName = if activeSurge ~= nil then activeSurge.reviverDisplayName else "",
		activeSurgeRescuedName = if activeSurge ~= nil then activeSurge.rescuedDisplayName else "",
		downedPlayers = buildDownedSnapshots(),
	})
end

local function buildPayloadForPlayer(player: Player)
	local entry = downedEntriesByUserId[player.UserId]

	return table.freeze({
		phaseName = rescueState.phaseName,
		roundNumber = rescueState.roundNumber,
		activeDownedCount = rescueState.activeDownedCount,
		totalRevives = rescueState.totalRevives,
		totalBleedouts = rescueState.totalBleedouts,
		activeSurgeLaneName = rescueState.activeSurgeLaneName,
		activeSurgeRemainingSeconds = rescueState.activeSurgeRemainingSeconds,
		activeSurgeReviverName = rescueState.activeSurgeReviverName,
		activeSurgeRescuedName = rescueState.activeSurgeRescuedName,
		downedPlayers = rescueState.downedPlayers,
		localIsDowned = entry ~= nil,
		localDownedLaneName = if entry ~= nil then entry.laneName else "",
		localBleedoutRemainingSeconds = if entry ~= nil then getRemainingBleedoutSeconds(entry) else 0,
	})
end

local function pushState(player: Player)
	getRemoteEvent():FireClient(player, buildPayloadForPlayer(player))
end

local function broadcastState()
	for _, player in ipairs(Players:GetPlayers()) do
		pushState(player)
	end
end

local function refreshState(phaseName: string, roundNumber: number)
	rebuildState(phaseName, roundNumber)
	broadcastState()
end

local function ensureRefreshLoop()
	refreshLoopToken += 1

	if rescueState.phaseName ~= "NightSurvival" then
		return
	end

	local loopToken = refreshLoopToken
	task.spawn(function()
		while
			loopToken == refreshLoopToken
			and rescueState.phaseName == "NightSurvival"
			and (rescueState.activeDownedCount > 0 or rescueState.activeSurgeRemainingSeconds > 0)
		do
			rebuildState(rescueState.phaseName, rescueState.roundNumber)
			broadcastState()
			task.wait(0.5)
		end
	end)
end

local function clearEntryArtifacts(entry)
	if entry.promptConnection ~= nil then
		entry.promptConnection:Disconnect()
		entry.promptConnection = nil
	end

	if entry.revivePrompt ~= nil and entry.revivePrompt.Parent ~= nil then
		entry.revivePrompt:Destroy()
	end

	if entry.highlight ~= nil and entry.highlight.Parent ~= nil then
		entry.highlight:Destroy()
	end
end

local function removeDownedEntry(userId: number)
	local entry = downedEntriesByUserId[userId]

	if entry == nil then
		return nil
	end

	downedEntriesByUserId[userId] = nil
	clearEntryArtifacts(entry)

	return entry
end

local function restoreStandingState(player: Player, entry, healthAmount: number)
	player:SetAttribute("IsDowned", false)
	player:SetAttribute("DownedLaneName", "")

	local _, humanoid = getCharacterState(player)

	if humanoid == nil then
		return
	end

	humanoid.WalkSpeed = entry.originalWalkSpeed
	humanoid.AutoRotate = entry.originalAutoRotate

	if humanoid.UseJumpPower then
		humanoid.JumpPower = entry.originalJumpPower
	else
		humanoid.JumpHeight = entry.originalJumpHeight
	end

	if humanoid.Health > 0 then
		humanoid.Health = math.max(humanoid.Health, healthAmount)
	end
end

local function moveCharacterToCamp(player: Player, desiredHealth: number)
	local connection = nil

	connection = player.CharacterAdded:Connect(function(character)
		if connection ~= nil then
			connection:Disconnect()
			connection = nil
		end

		task.defer(function()
			local humanoid = character:FindFirstChildOfClass("Humanoid")
			local rootPart = character:FindFirstChild("HumanoidRootPart")

			player:SetAttribute("IsDowned", false)
			player:SetAttribute("DownedLaneName", "")

			if humanoid ~= nil then
				humanoid.Health = math.max(humanoid.Health, desiredHealth)
			end

			if rootPart ~= nil and objectiveService ~= nil then
				rootPart.CFrame = CFrame.new(objectiveService.getCampCenter() + Vector3.new(0, 6, 0))
			end
		end)
	end)

	player:LoadCharacter()
end

local function applyDownedState(player: Player, laneName: string)
	if rescueState.phaseName ~= "NightSurvival" then
		return false
	end

	if downedEntriesByUserId[player.UserId] ~= nil then
		return false
	end

	local character, humanoid, rootPart = getCharacterState(player)

	if character == nil or humanoid == nil or rootPart == nil or humanoid.Health <= 0 then
		return false
	end

	local revivePrompt = Instance.new("ProximityPrompt")
	revivePrompt.Name = "RevivePrompt"
	revivePrompt.ActionText = "Revive"
	revivePrompt.ObjectText = string.format("%s | %s lane", player.DisplayName, laneName)
	revivePrompt.HoldDuration = GameConfig.RescueTuning.ReviveHoldSeconds
	revivePrompt.MaxActivationDistance = 12
	revivePrompt.RequiresLineOfSight = false
	revivePrompt.Parent = rootPart

	local highlight = Instance.new("Highlight")
	highlight.Name = "DownedHighlight"
	highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
	highlight.FillTransparency = 0.55
	highlight.OutlineTransparency = 0.05
	highlight.FillColor = Color3.fromRGB(255, 170, 110)
	highlight.OutlineColor = Color3.fromRGB(255, 238, 198)
	highlight.Parent = character

	local entry = {
		laneName = laneName,
		bleedoutEndsAt = os.clock() + GameConfig.RescueTuning.BleedoutSeconds,
		revivePrompt = revivePrompt,
		highlight = highlight,
		originalWalkSpeed = humanoid.WalkSpeed,
		originalJumpPower = humanoid.JumpPower,
		originalJumpHeight = humanoid.JumpHeight,
		originalAutoRotate = humanoid.AutoRotate,
		promptConnection = nil,
	}

	player:SetAttribute("IsDowned", true)
	player:SetAttribute("DownedLaneName", laneName)
	humanoid:UnequipTools()
	humanoid.WalkSpeed = GameConfig.RescueTuning.DownedWalkSpeed
	humanoid.AutoRotate = false

	if humanoid.UseJumpPower then
		humanoid.JumpPower = GameConfig.RescueTuning.DownedJumpPower
	else
		humanoid.JumpHeight = 0
	end

	humanoid.Health = math.max(1, math.min(humanoid.MaxHealth, GameConfig.RescueTuning.DownedHealth))

	entry.promptConnection = revivePrompt.Triggered:Connect(function(reviver)
		if reviver == nil or reviver.UserId == player.UserId then
			return
		end

		if RescueService.isPlayerDowned(reviver) then
			return
		end

		local _, reviverHumanoid, reviverRootPart = getCharacterState(reviver)

		if reviverHumanoid == nil or reviverHumanoid.Health <= 0 or reviverRootPart == nil then
			return
		end

		local _, _, targetRootPart = getCharacterState(player)

		if targetRootPart == nil then
			return
		end

		if (reviverRootPart.Position - targetRootPart.Position).Magnitude > 14 then
			return
		end

		local removedEntry = removeDownedEntry(player.UserId)

		if removedEntry == nil then
			return
		end

		totalRevives += 1
		activeSurge = {
			laneName = removedEntry.laneName,
			endsAt = os.clock() + GameConfig.RescueTuning.SurgeDurationSeconds,
			reviverDisplayName = reviver.DisplayName,
			rescuedDisplayName = player.DisplayName,
		}
		restoreStandingState(player, removedEntry, GameConfig.RescueTuning.ReviveHealth)
		reviver:SetAttribute("LastRescueAt", os.time())
		refreshState(rescueState.phaseName, rescueState.roundNumber)
		ensureRefreshLoop()
	end)

	downedEntriesByUserId[player.UserId] = entry
	refreshState(rescueState.phaseName, rescueState.roundNumber)
	ensureRefreshLoop()

	local nightToken = currentNightToken
	task.spawn(function()
		task.wait(GameConfig.RescueTuning.BleedoutSeconds)

		if rescueState.phaseName ~= "NightSurvival" or nightToken ~= currentNightToken then
			return
		end

		local removedEntry = removeDownedEntry(player.UserId)

		if removedEntry == nil then
			return
		end

		totalBleedouts += 1
		player:SetAttribute("IsDowned", false)
		player:SetAttribute("DownedLaneName", "")
		refreshState(rescueState.phaseName, rescueState.roundNumber)
		ensureRefreshLoop()
		moveCharacterToCamp(player, GameConfig.RescueTuning.RespawnHealth)
	end)

	return true
end

local function clearAllDownedEntries(healthAmount: number)
	for userId, _ in pairs(downedEntriesByUserId) do
		local removedEntry = removeDownedEntry(userId)
		local player = Players:GetPlayerByUserId(userId)

		if removedEntry ~= nil and player ~= nil then
			restoreStandingState(player, removedEntry, healthAmount)
		end
	end
end

function RescueService.initialize(dependencies)
	objectiveService = dependencies.objectiveService

	local function attachCharacterReset(player: Player)
		player:SetAttribute("IsDowned", false)
		player:SetAttribute("DownedLaneName", "")

		player.CharacterAdded:Connect(function()
			local removedEntry = removeDownedEntry(player.UserId)

			if removedEntry ~= nil then
				refreshState(rescueState.phaseName, rescueState.roundNumber)
				ensureRefreshLoop()
			end

			player:SetAttribute("IsDowned", false)
			player:SetAttribute("DownedLaneName", "")
		end)
	end

	Players.PlayerAdded:Connect(attachCharacterReset)
	Players.PlayerRemoving:Connect(function(player)
		local removedEntry = removeDownedEntry(player.UserId)

		if removedEntry ~= nil then
			refreshState(rescueState.phaseName, rescueState.roundNumber)
			ensureRefreshLoop()
		end
	end)

	for _, player in ipairs(Players:GetPlayers()) do
		attachCharacterReset(player)
	end

	rebuildState("Lobby", 0)
	broadcastState()
end

function RescueService.startNightPhase(roundNumber: number)
	currentNightToken += 1
	totalRevives = 0
	totalBleedouts = 0
	activeSurge = nil
	clearAllDownedEntries(GameConfig.RescueTuning.RespawnHealth)
	refreshState("NightSurvival", roundNumber)

	return rescueState
end

function RescueService.finishRound(roundNumber: number)
	currentNightToken += 1
	activeSurge = nil
	clearAllDownedEntries(GameConfig.RescueTuning.RespawnHealth)
	refreshState("Results", roundNumber)

	return rescueState
end

function RescueService.findInterceptTarget(threatPosition: Vector3)
	if rescueState.phaseName ~= "NightSurvival" then
		return nil
	end

	local nearestTarget = nil
	local nearestDistance = GameConfig.RescueTuning.PlayerInterceptDistance

	for _, player in ipairs(Players:GetPlayers()) do
		if not RescueService.isPlayerDowned(player) then
			local _, humanoid, rootPart = getCharacterState(player)

			if humanoid ~= nil and humanoid.Health > 0 and rootPart ~= nil then
				local distance = (rootPart.Position - threatPosition).Magnitude

				if distance <= nearestDistance then
					nearestTarget = {
						player = player,
						position = rootPart.Position,
						distance = distance,
					}
					nearestDistance = distance
				end
			end
		end
	end

	return nearestTarget
end

function RescueService.getDownedCountForLane(laneName: string): number
	local downedCount = 0

	for _, entry in pairs(downedEntriesByUserId) do
		if entry.laneName == laneName then
			downedCount += 1
		end
	end

	return downedCount
end

function RescueService.getPriorityLaneName(threatTypeName: string, allowedLaneNames)
	if rescueState.phaseName ~= "NightSurvival" then
		return nil
	end

	local allowedLookup = {}

	if type(allowedLaneNames) == "table" and #allowedLaneNames > 0 then
		for _, laneName in ipairs(allowedLaneNames) do
			allowedLookup[laneName] = true
		end
	end

	local function laneAllowed(laneName: string): boolean
		if next(allowedLookup) == nil then
			return true
		end

		return allowedLookup[laneName] == true
	end

	if threatTypeName == "Runner" then
		local bestLaneName = nil
		local shortestBleedout = math.huge

		for _, entry in pairs(downedEntriesByUserId) do
			local remainingSeconds = getRemainingBleedoutSeconds(entry)

			if laneAllowed(entry.laneName) and remainingSeconds < shortestBleedout then
				bestLaneName = entry.laneName
				shortestBleedout = remainingSeconds
			end
		end

		return bestLaneName
	end

	if
		threatTypeName == "Sapper"
		and activeSurge ~= nil
		and activeSurge.endsAt > os.clock()
		and laneAllowed(activeSurge.laneName)
	then
		return activeSurge.laneName
	end

	return nil
end

function RescueService.applyThreatHit(player: Player, damageAmount: number, laneName: string)
	if rescueState.phaseName ~= "NightSurvival" or RescueService.isPlayerDowned(player) then
		return false
	end

	local _, humanoid = getCharacterState(player)

	if humanoid == nil or humanoid.Health <= 0 then
		return false
	end

	local postHitHealth = humanoid.Health - damageAmount

	if postHitHealth > GameConfig.RescueTuning.DownedHealth then
		humanoid.Health = postHitHealth
		return true
	end

	return applyDownedState(player, laneName)
end

function RescueService.isPlayerDowned(player: Player): boolean
	return downedEntriesByUserId[player.UserId] ~= nil or player:GetAttribute("IsDowned") == true
end

function RescueService.getLaneModifiers(laneName: string)
	if
		rescueState.phaseName ~= "NightSurvival"
		or activeSurge == nil
		or activeSurge.laneName ~= laneName
		or activeSurge.endsAt <= os.clock()
	then
		return EMPTY_LANE_MODIFIERS
	end

	return table.freeze({
		towerDamageBonus = GameConfig.RescueTuning.SurgeTowerDamageBonus,
		towerRangeBonus = GameConfig.RescueTuning.SurgeTowerRangeBonus,
		barricadeMitigationBonus = GameConfig.RescueTuning.SurgeBarricadeMitigationBonus,
	})
end

function RescueService.getCombatModifiers()
	if rescueState.phaseName ~= "NightSurvival" or activeSurge == nil or activeSurge.endsAt <= os.clock() then
		return EMPTY_COMBAT_MODIFIERS
	end

	return table.freeze({
		meleeDamageBonus = GameConfig.RescueTuning.SurgeMeleeDamageBonus,
		pulseDamageBonus = GameConfig.RescueTuning.SurgePulseDamageBonus,
		pulseCooldownDelta = GameConfig.RescueTuning.SurgePulseCooldownDelta,
	})
end

function RescueService.getState()
	return rescueState
end

function RescueService.syncPlayer(player: Player)
	pushState(player)
end

return RescueService
]]></ProtectedString>
						<string name="ScriptGuid">{359BD5D8-4CB2-4D5E-8991-7A05EAC73B38}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">RescueService</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">4be6c94ec416c0c409e3a308000003ac</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="21">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local RewardService = {}

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = ReplicatedStorage:WaitForChild("Shared")
local GameConfig = require(Shared:WaitForChild("GameConfig"))

function RewardService.calculateRewards(roundOutcome, echoState, dutyState)
	local rewardTuning = GameConfig.RewardTuning
	local echoTuning = GameConfig.EchoTuning
	local objectiveCoins = roundOutcome.objectivesCompleted * rewardTuning.ObjectiveCoins
	local objectiveExperience = roundOutcome.objectivesCompleted * rewardTuning.ObjectiveExperience
	local defenseBonus = (roundOutcome.barricadesStanding * rewardTuning.BarricadeHoldCoins)
		+ (roundOutcome.fortificationLevel * rewardTuning.FortificationCoins)
		+ (roundOutcome.overchargeLevel * rewardTuning.OverchargeCoins)
	local preparednessBonus = roundOutcome.suppliesSpent * rewardTuning.SupplySpendCoins
	local socialBonus = (roundOutcome.teamCoverageCount * rewardTuning.TeamCoverageCoins)
		+ (roundOutcome.concordLanes * rewardTuning.ConcordLaneCoins)
		+ ((roundOutcome.revivesCompleted or 0) * rewardTuning.ReviveCoins)
	local echoBonus = 0
	local dutyBonus = 0
	local clearBonus = if roundOutcome.nightCleared then rewardTuning.NightClearCoins else 0

	if echoState ~= nil then
		echoBonus = (echoState.completedDirectives or 0) * echoTuning.RewardCoinsPerDirective

		if echoState.latestUnlockedBoonName ~= "" then
			echoBonus += echoTuning.NewBoonCoins
		end
	end

	if dutyState ~= nil then
		dutyBonus = (dutyState.completedDutyCount or 0) * GameConfig.DutyTuning.RewardCoinsPerCompleted

		if dutyState.fullRosterBonusReady then
			dutyBonus += GameConfig.DutyTuning.FullRosterCoins
		end
	end

	local survivalRatio = 0
	if roundOutcome.totalPlayers > 0 then
		survivalRatio = roundOutcome.alivePlayers / roundOutcome.totalPlayers
	end

	local survivalBonus =
		math.floor((rewardTuning.BaseCoins + objectiveCoins) * survivalRatio * rewardTuning.SurvivalBonusMultiplier)
	local lanternBonus = math.floor(roundOutcome.lanternCharge * rewardTuning.LanternChargeBonus)
	local defenseExperience = math.floor(defenseBonus * 0.6)
	local preparednessExperience = math.floor(preparednessBonus * 0.5)
	local socialExperience = math.floor(
		(roundOutcome.teamCoverageCount * rewardTuning.TeamCoverageCoins * 0.5)
			+ (roundOutcome.concordLanes * rewardTuning.ConcordLaneCoins * 0.5)
			+ ((roundOutcome.revivesCompleted or 0) * rewardTuning.ReviveExperience)
	)
	local echoExperience = 0

	if echoState ~= nil then
		echoExperience = (echoState.completedDirectives or 0) * echoTuning.RewardExperiencePerDirective

		if echoState.latestUnlockedBoonName ~= "" then
			echoExperience += echoTuning.NewBoonExperience
		end
	end

	local dutyExperience = 0

	if dutyState ~= nil then
		dutyExperience = (dutyState.completedDutyCount or 0) * GameConfig.DutyTuning.RewardExperiencePerCompleted

		if dutyState.fullRosterBonusReady then
			dutyExperience += GameConfig.DutyTuning.FullRosterExperience
		end
	end

	local clearExperience = if roundOutcome.nightCleared then rewardTuning.NightClearExperience else 0

	return table.freeze({
		coins = rewardTuning.BaseCoins
			+ objectiveCoins
			+ survivalBonus
			+ lanternBonus
			+ defenseBonus
			+ preparednessBonus
			+ socialBonus
			+ echoBonus
			+ dutyBonus
			+ clearBonus,
		experience = rewardTuning.BaseExperience
			+ objectiveExperience
			+ lanternBonus
			+ defenseExperience
			+ preparednessExperience
			+ socialExperience
			+ echoExperience
			+ dutyExperience
			+ clearExperience,
		survivalBonus = survivalBonus,
		lanternBonus = lanternBonus,
		defenseBonus = defenseBonus,
		preparednessBonus = preparednessBonus,
		socialBonus = socialBonus,
		echoBonus = echoBonus,
		dutyBonus = dutyBonus,
		clearBonus = clearBonus,
	})
end

return RewardService
]]></ProtectedString>
						<string name="ScriptGuid">{C3D7BB3B-30DE-444F-AF0A-AE2561D2A1AD}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">RewardService</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">4be6c94ec416c0c409e3a308000003ad</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="22">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = ReplicatedStorage:WaitForChild("Shared")
local GameConfig = require(Shared:WaitForChild("GameConfig"))
local RemoteNames = require(Shared:WaitForChild("RemoteNames"))

local RiteFocusService = {}

local EMPTY_LANE_MODIFIERS = table.freeze({
	towerDamageBonus = 0,
	towerRangeBonus = 0,
	barricadeMitigationBonus = 0,
})

local EMPTY_THREAT_MODIFIERS = table.freeze({
	speedMultiplier = 1,
})

local EMPTY_COMBAT_MODIFIERS = table.freeze({
	pulseDamageBonus = 0,
	pulseCooldownDelta = 0,
	pulseRadiusBonus = 0,
})

local objectiveService = nil
local defenseService = nil
local riteService = nil
local focusFolder = nil
local focusEntriesByLaneName = {}
local laneCooldownEndsAtByName = {}
local refreshLoopToken = 0
local activeFocus = nil
local focusState = table.freeze({
	phaseName = "Lobby",
	roundNumber = 0,
	selectedRiteName = "",
	selectedRiteTitle = "",
	selectedRiteSummary = "",
	activeLaneName = "",
	activeTitle = "",
	activeSummary = "",
	activeRemainingSeconds = 0,
	lanes = table.freeze({}),
})

local function getRemoteEvent(): RemoteEvent
	local remoteFolder = ReplicatedStorage:WaitForChild(RemoteNames.Folder)
	return remoteFolder:WaitForChild(RemoteNames.RiteFocusStateChanged) :: RemoteEvent
end

local function getFocusFolder()
	if focusFolder ~= nil and focusFolder.Parent ~= nil then
		return focusFolder
	end

	local runtimeFolder = objectiveService.getRuntimeFolder()
	local existingFolder = runtimeFolder:FindFirstChild("RiteFoci")

	if existingFolder ~= nil then
		focusFolder = existingFolder
		return focusFolder
	end

	focusFolder = Instance.new("Folder")
	focusFolder.Name = "RiteFoci"
	focusFolder.Parent = runtimeFolder

	return focusFolder
end

local function getSelectedRiteConfig()
	if focusState.selectedRiteName == "" then
		return nil
	end

	return GameConfig.RiteFocusTuning.Rites[focusState.selectedRiteName]
end

local function getActiveRemainingSeconds(): number
	if activeFocus == nil then
		return 0
	end

	return math.max(0, math.ceil(activeFocus.endsAt - os.clock()))
end

local function getLaneCooldownRemainingSeconds(laneName: string): number
	return math.max(0, math.ceil((laneCooldownEndsAtByName[laneName] or 0) - os.clock()))
end

local function pruneExpiredFocus()
	if activeFocus ~= nil and getActiveRemainingSeconds() <= 0 then
		activeFocus = nil
	end
end

local function hasAnyCooldowns(): boolean
	local expiredLaneNames = {}

	for laneName, endsAt in pairs(laneCooldownEndsAtByName) do
		if endsAt > os.clock() then
			return true
		end

		table.insert(expiredLaneNames, laneName)
	end

	for _, laneName in ipairs(expiredLaneNames) do
		laneCooldownEndsAtByName[laneName] = nil
	end

	return false
end

local function buildFocusPosition(laneName: string): Vector3
	local beaconPosition = defenseService.getLaneBeaconPosition(laneName)
	local campCenter = objectiveService.getCampCenter()
	local outwardDirection = beaconPosition - campCenter
	local flatDirection = Vector3.new(outwardDirection.X, 0, outwardDirection.Z)

	if flatDirection.Magnitude < 0.001 then
		flatDirection = Vector3.new(0, 0, -1)
	else
		flatDirection = flatDirection.Unit
	end

	return beaconPosition + (flatDirection * GameConfig.RiteFocusTuning.FocusOffset) + Vector3.new(0, -3, 0)
end

local function updateFocusVisuals(laneName: string)
	local focusEntry = focusEntriesByLaneName[laneName]

	if focusEntry == nil then
		return
	end

	pruneExpiredFocus()

	local isNight = focusState.phaseName == "NightSurvival"
	local riteConfig = getSelectedRiteConfig()
	local isActive = activeFocus ~= nil and activeFocus.laneName == laneName
	local cooldownRemainingSeconds = getLaneCooldownRemainingSeconds(laneName)
	local baseColor = if riteConfig ~= nil
		then GameConfig.RiteTuning.Rites[focusState.selectedRiteName].color
		else Color3.fromRGB(205, 189, 142)

	focusEntry.focus.Color = if isActive then Color3.fromRGB(255, 244, 176) else baseColor
	focusEntry.light.Color = if isActive then Color3.fromRGB(255, 236, 162) else baseColor
	focusEntry.light.Brightness = if isActive then 4.2 else if isNight and riteConfig ~= nil then 1.8 else 0.8
	focusEntry.light.Range = if isActive then 20 else if isNight and riteConfig ~= nil then 12 else 8
	focusEntry.prompt.Enabled = isNight and riteConfig ~= nil and not isActive and cooldownRemainingSeconds <= 0

	if isActive and activeFocus ~= nil then
		focusEntry.titleLabel.Text = string.format("%s Active", activeFocus.title)
		focusEntry.bodyLabel.Text = string.format("%s\n%ss remaining", activeFocus.summary, getActiveRemainingSeconds())
		focusEntry.prompt.ActionText = activeFocus.actionText
		focusEntry.prompt.ObjectText = string.format("%s lane active", laneName)
		return
	end

	if riteConfig ~= nil and isNight then
		focusEntry.titleLabel.Text = string.format("%s Focus", focusState.selectedRiteTitle)

		if cooldownRemainingSeconds > 0 then
			focusEntry.bodyLabel.Text =
				string.format("%s\nCooldown %ss", riteConfig.focusSummary, cooldownRemainingSeconds)
		else
			focusEntry.bodyLabel.Text =
				string.format("%s\nHold to invoke on %s lane.", riteConfig.focusSummary, laneName)
		end

		focusEntry.prompt.ActionText = riteConfig.actionText
		focusEntry.prompt.ObjectText = string.format("%s lane focus", laneName)
		return
	end

	focusEntry.titleLabel.Text = string.format("%s Font", laneName)
	focusEntry.bodyLabel.Text = "The active rite can be channeled here once night begins."
	focusEntry.prompt.ActionText = "Await Rite"
	focusEntry.prompt.ObjectText = string.format("%s lane", laneName)
end

local function refreshFocusVisuals()
	for laneName, _ in pairs(focusEntriesByLaneName) do
		updateFocusVisuals(laneName)
	end
end

local function rebuildState()
	pruneExpiredFocus()

	local laneSnapshots = {}

	for _, laneName in ipairs(defenseService.getLaneNames()) do
		table.insert(
			laneSnapshots,
			table.freeze({
				name = laneName,
				cooldownRemainingSeconds = getLaneCooldownRemainingSeconds(laneName),
				isActive = activeFocus ~= nil and activeFocus.laneName == laneName,
			})
		)
	end

	focusState = table.freeze({
		phaseName = focusState.phaseName,
		roundNumber = focusState.roundNumber,
		selectedRiteName = focusState.selectedRiteName,
		selectedRiteTitle = focusState.selectedRiteTitle,
		selectedRiteSummary = focusState.selectedRiteSummary,
		activeLaneName = if activeFocus ~= nil then activeFocus.laneName else "",
		activeTitle = if activeFocus ~= nil then activeFocus.title else "",
		activeSummary = if activeFocus ~= nil then activeFocus.summary else "",
		activeRemainingSeconds = getActiveRemainingSeconds(),
		lanes = table.freeze(laneSnapshots),
	})
end

local function broadcastState()
	rebuildState()
	refreshFocusVisuals()
	getRemoteEvent():FireAllClients(focusState)
end

local function pushState(player: Player)
	rebuildState()
	getRemoteEvent():FireClient(player, focusState)
end

local function startRefreshLoop()
	refreshLoopToken += 1

	if activeFocus == nil and not hasAnyCooldowns() then
		return
	end

	local loopToken = refreshLoopToken

	task.spawn(function()
		while loopToken == refreshLoopToken do
			pruneExpiredFocus()

			if activeFocus == nil and not hasAnyCooldowns() then
				broadcastState()
				break
			end

			broadcastState()
			task.wait(0.5)
		end
	end)
end

local function createPrompt(parent: Instance, laneName: string)
	local prompt = parent:FindFirstChild("InvokePrompt")

	if prompt ~= nil and prompt:IsA("ProximityPrompt") then
		return prompt
	end

	prompt = Instance.new("ProximityPrompt")
	prompt.Name = "InvokePrompt"
	prompt.ActionText = "Await Rite"
	prompt.ObjectText = string.format("%s lane", laneName)
	prompt.HoldDuration = GameConfig.RiteFocusTuning.PromptHoldDuration
	prompt.MaxActivationDistance = GameConfig.RiteFocusTuning.PromptDistance
	prompt.Parent = parent

	return prompt
end

local function buildLaneFocus(laneName: string)
	local folder = getFocusFolder()
	local laneFolder = folder:FindFirstChild(laneName)

	if laneFolder == nil then
		laneFolder = Instance.new("Folder")
		laneFolder.Name = laneName
		laneFolder.Parent = folder
	end

	local focusPosition = buildFocusPosition(laneName)

	local pedestal = laneFolder:FindFirstChild("Pedestal")
	if pedestal == nil then
		pedestal = Instance.new("Part")
		pedestal.Name = "Pedestal"
		pedestal.Anchored = true
		pedestal.CanCollide = false
		pedestal.Material = Enum.Material.Slate
		pedestal.Color = Color3.fromRGB(86, 88, 98)
		pedestal.Parent = laneFolder
	end

	pedestal.Size = Vector3.new(3.2, 1.4, 3.2)
	pedestal.Position = focusPosition + Vector3.new(0, 0.7, 0)

	local focus = laneFolder:FindFirstChild("Focus")
	if focus == nil then
		focus = Instance.new("Part")
		focus.Name = "Focus"
		focus.Anchored = true
		focus.CanCollide = false
		focus.Shape = Enum.PartType.Ball
		focus.Material = Enum.Material.Neon
		focus.Parent = laneFolder

		local light = Instance.new("PointLight")
		light.Name = "FocusLight"
		light.Parent = focus

		local billboard = Instance.new("BillboardGui")
		billboard.Name = "Label"
		billboard.Size = UDim2.fromOffset(220, 82)
		billboard.StudsOffset = Vector3.new(0, 3.2, 0)
		billboard.AlwaysOnTop = true
		billboard.MaxDistance = 90
		billboard.Parent = focus

		local container = Instance.new("Frame")
		container.Name = "Container"
		container.BackgroundColor3 = Color3.fromRGB(18, 20, 24)
		container.BackgroundTransparency = 0.14
		container.Size = UDim2.fromScale(1, 1)
		container.Parent = billboard

		local corner = Instance.new("UICorner")
		corner.CornerRadius = UDim.new(0, 10)
		corner.Parent = container

		local stroke = Instance.new("UIStroke")
		stroke.Color = Color3.fromRGB(255, 210, 112)
		stroke.Transparency = 0.32
		stroke.Parent = container

		local titleLabel = Instance.new("TextLabel")
		titleLabel.Name = "TitleLabel"
		titleLabel.BackgroundTransparency = 1
		titleLabel.Position = UDim2.fromOffset(8, 6)
		titleLabel.Size = UDim2.new(1, -16, 0, 18)
		titleLabel.Font = Enum.Font.GothamBold
		titleLabel.TextSize = 14
		titleLabel.TextColor3 = Color3.fromRGB(255, 232, 174)
		titleLabel.TextXAlignment = Enum.TextXAlignment.Left
		titleLabel.Parent = container

		local bodyLabel = Instance.new("TextLabel")
		bodyLabel.Name = "BodyLabel"
		bodyLabel.BackgroundTransparency = 1
		bodyLabel.Position = UDim2.fromOffset(8, 26)
		bodyLabel.Size = UDim2.new(1, -16, 1, -32)
		bodyLabel.Font = Enum.Font.Gotham
		bodyLabel.TextSize = 12
		bodyLabel.TextWrapped = true
		bodyLabel.TextColor3 = Color3.fromRGB(233, 232, 226)
		bodyLabel.TextXAlignment = Enum.TextXAlignment.Left
		bodyLabel.TextYAlignment = Enum.TextYAlignment.Top
		bodyLabel.Parent = container
	end

	focus.Size = Vector3.new(2.2, 2.2, 2.2)
	focus.Position = focusPosition + Vector3.new(0, 2.6, 0)

	local light = focus:FindFirstChild("FocusLight") :: PointLight
	local label = focus:FindFirstChild("Label")
	local container = if label ~= nil then label:FindFirstChild("Container") else nil
	local titleLabel = if container ~= nil then container:FindFirstChild("TitleLabel") else nil
	local bodyLabel = if container ~= nil then container:FindFirstChild("BodyLabel") else nil
	local prompt = createPrompt(focus, laneName)

	prompt.Triggered:Connect(function()
		if focusState.phaseName ~= "NightSurvival" or activeFocus ~= nil then
			return
		end

		local riteConfig = getSelectedRiteConfig()

		if riteConfig == nil or getLaneCooldownRemainingSeconds(laneName) > 0 then
			return
		end

		local nowTime = os.clock()
		local immediate = riteConfig.immediate

		activeFocus = {
			laneName = laneName,
			title = riteConfig.focusTitle,
			summary = riteConfig.focusSummary,
			actionText = riteConfig.actionText,
			endsAt = nowTime + GameConfig.RiteFocusTuning.FocusDurationSeconds,
		}
		laneCooldownEndsAtByName[laneName] = nowTime + GameConfig.RiteFocusTuning.LaneCooldownSeconds
		defenseService.applyLaneRestoration(
			laneName,
			immediate.barricadeRestore or 0,
			immediate.towerEnergyRestore or 0
		)
		broadcastState()
		startRefreshLoop()
	end)

	focusEntriesByLaneName[laneName] = {
		focus = focus,
		light = light,
		prompt = prompt,
		titleLabel = titleLabel,
		bodyLabel = bodyLabel,
	}
end

local function setPhase(
	phaseName: string,
	roundNumber: number,
	selectedRiteName: string,
	selectedRiteTitle: string,
	selectedRiteSummary: string
)
	activeFocus = nil
	laneCooldownEndsAtByName = {}
	focusState = table.freeze({
		phaseName = phaseName,
		roundNumber = roundNumber,
		selectedRiteName = selectedRiteName,
		selectedRiteTitle = selectedRiteTitle,
		selectedRiteSummary = selectedRiteSummary,
		activeLaneName = "",
		activeTitle = "",
		activeSummary = "",
		activeRemainingSeconds = 0,
		lanes = table.freeze({}),
	})
	refreshLoopToken += 1
	broadcastState()
end

function RiteFocusService.initialize(dependencies)
	objectiveService = dependencies.objectiveService
	defenseService = dependencies.defenseService
	riteService = dependencies.riteService

	for _, laneName in ipairs(defenseService.getLaneNames()) do
		buildLaneFocus(laneName)
	end

	setPhase("Lobby", 0, "", "", "")
end

function RiteFocusService.startDayPhase(roundNumber: number)
	setPhase("DayPrep", roundNumber, "", "", "")
	return focusState
end

function RiteFocusService.startNightPhase(roundNumber: number)
	local riteState = riteService.getState()
	setPhase(
		"NightSurvival",
		roundNumber,
		riteState.selectedRiteName or "",
		riteState.selectedRiteTitle or "",
		riteState.selectedRiteSummary or ""
	)
	return focusState
end

function RiteFocusService.finishRound(roundNumber: number)
	setPhase(
		"Results",
		roundNumber,
		focusState.selectedRiteName,
		focusState.selectedRiteTitle,
		focusState.selectedRiteSummary
	)
	return focusState
end

function RiteFocusService.getLaneModifiers(laneName: string)
	pruneExpiredFocus()
	local riteConfig = getSelectedRiteConfig()

	if activeFocus == nil or activeFocus.laneName ~= laneName or riteConfig == nil then
		return EMPTY_LANE_MODIFIERS
	end

	return riteConfig.laneModifiers or EMPTY_LANE_MODIFIERS
end

function RiteFocusService.getThreatModifiers(laneName: string)
	pruneExpiredFocus()
	local riteConfig = getSelectedRiteConfig()

	if activeFocus == nil or activeFocus.laneName ~= laneName or riteConfig == nil then
		return EMPTY_THREAT_MODIFIERS
	end

	return riteConfig.threatModifiers or EMPTY_THREAT_MODIFIERS
end

function RiteFocusService.getCombatModifiers()
	pruneExpiredFocus()
	local riteConfig = getSelectedRiteConfig()

	if activeFocus == nil or riteConfig == nil then
		return EMPTY_COMBAT_MODIFIERS
	end

	return riteConfig.combatModifiers or EMPTY_COMBAT_MODIFIERS
end

function RiteFocusService.getState()
	rebuildState()
	return focusState
end

function RiteFocusService.syncPlayer(player: Player)
	pushState(player)
end

return RiteFocusService
]]></ProtectedString>
						<string name="ScriptGuid">{F6AD8609-A181-4CE9-B922-A4B884FA1A9F}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">RiteFocusService</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">4be6c94ec416c0c409e3a308000003ae</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="23">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = ReplicatedStorage:WaitForChild("Shared")
local GameConfig = require(Shared:WaitForChild("GameConfig"))
local RemoteNames = require(Shared:WaitForChild("RemoteNames"))

local RiteService = {}

local EMPTY_MODIFIERS = table.freeze({
	pulseCooldownDelta = 0,
	pulseDamageBonus = 0,
	pulseRadiusBonus = 0,
	towerDamageBonus = 0,
	towerRangeBonus = 0,
	warningLeadBonus = 0,
	globalThreatSpeedMultiplier = 1,
	runnerSpeedMultiplier = 1,
	barricadeMitigationBonus = 0,
	lanternHealthBonus = 0,
	sapperDamageMultiplier = 1,
})

local objectiveService = nil
local shrineFolder = nil
local shrineEntriesByName = {}
local votesByUserId = {}
local riteState = table.freeze({
	phaseName = "Lobby",
	roundNumber = 0,
	lockedIn = false,
	leadingRiteName = "",
	leadingRiteTitle = "",
	leadingRiteSummary = "",
	leadingRiteVotes = 0,
	selectedRiteName = "",
	selectedRiteTitle = "",
	selectedRiteSummary = "",
	votedRiteName = "",
	votedRiteTitle = "",
	votedRiteSummary = "",
	rites = table.freeze({}),
})

local function getRemoteEvent(): RemoteEvent
	local remoteFolder = ReplicatedStorage:WaitForChild(RemoteNames.Folder)
	return remoteFolder:WaitForChild(RemoteNames.RiteStateChanged) :: RemoteEvent
end

local function setRiteState(nextState)
	riteState = table.freeze(nextState)
end

local function getRiteOrder()
	return GameConfig.RiteTuning.Order
end

local function getRiteConfig(riteName: string)
	return GameConfig.RiteTuning.Rites[riteName]
end

local function getVotedRiteNameForUserId(userId: number): string
	local votedRiteName = votesByUserId[userId]

	if type(votedRiteName) ~= "string" then
		return ""
	end

	if getRiteConfig(votedRiteName) == nil then
		return ""
	end

	return votedRiteName
end

local function getDefaultRiteName(roundNumber: number): string
	local riteOrder = getRiteOrder()
	local orderIndex = ((math.max(roundNumber, 1) - 1) % #riteOrder) + 1

	return riteOrder[orderIndex]
end

local function getVoteCounts()
	local voteCounts = {}

	for _, riteName in ipairs(getRiteOrder()) do
		voteCounts[riteName] = 0
	end

	for _, riteName in pairs(votesByUserId) do
		if voteCounts[riteName] ~= nil then
			voteCounts[riteName] += 1
		end
	end

	return voteCounts
end

local function getTieBreakOrder(roundNumber: number)
	local riteOrder = getRiteOrder()
	local rotatedOrder = {}
	local defaultIndex = ((math.max(roundNumber, 1) - 1) % #riteOrder) + 1

	for offset = 0, #riteOrder - 1 do
		local orderIndex = ((defaultIndex + offset - 1) % #riteOrder) + 1
		table.insert(rotatedOrder, riteOrder[orderIndex])
	end

	return rotatedOrder
end

local function determineLeadingRiteName(roundNumber: number, voteCounts)
	local bestRiteName = getDefaultRiteName(roundNumber)
	local bestVotes = -1

	for _, riteName in ipairs(getTieBreakOrder(roundNumber)) do
		local voteCount = voteCounts[riteName] or 0

		if voteCount > bestVotes then
			bestVotes = voteCount
			bestRiteName = riteName
		end
	end

	return bestRiteName
end

local function getShrineFolder()
	if shrineFolder ~= nil and shrineFolder.Parent ~= nil then
		return shrineFolder
	end

	local runtimeFolder = objectiveService.getRuntimeFolder()
	local existingFolder = runtimeFolder:FindFirstChild("LanternRites")

	if existingFolder ~= nil then
		shrineFolder = existingFolder
		return shrineFolder
	end

	shrineFolder = Instance.new("Folder")
	shrineFolder.Name = "LanternRites"
	shrineFolder.Parent = runtimeFolder

	return shrineFolder
end

local function buildShrinePosition(index: number, totalShrines: number): Vector3
	local angle = (-math.pi / 2) + (((index - 1) / math.max(totalShrines, 1)) * math.pi * 2)
	local radius = GameConfig.RiteTuning.ShrineRadius

	return Vector3.new(math.cos(angle) * radius, 4, math.sin(angle) * radius)
end

local function buildRiteState(
	phaseName: string,
	roundNumber: number,
	lockedIn: boolean,
	selectedRiteName: string,
	player: Player?
)
	local voteCounts = getVoteCounts()
	local leadingRiteName = determineLeadingRiteName(roundNumber, voteCounts)
	local activeSelectedRiteName = if lockedIn and selectedRiteName == "" then leadingRiteName else selectedRiteName
	local votedRiteName = if player ~= nil then getVotedRiteNameForUserId(player.UserId) else ""
	local leadingRiteConfig = getRiteConfig(leadingRiteName)
	local selectedRiteConfig = if activeSelectedRiteName ~= "" then getRiteConfig(activeSelectedRiteName) else nil
	local votedRiteConfig = if votedRiteName ~= "" then getRiteConfig(votedRiteName) else nil
	local riteSnapshots = {}

	for _, riteName in ipairs(getRiteOrder()) do
		local riteConfig = getRiteConfig(riteName)
		table.insert(
			riteSnapshots,
			table.freeze({
				name = riteName,
				title = riteConfig.title,
				summary = riteConfig.summary,
				votes = voteCounts[riteName] or 0,
				isLeading = riteName == leadingRiteName,
				isSelected = lockedIn and riteName == activeSelectedRiteName,
			})
		)
	end

	return table.freeze({
		phaseName = phaseName,
		roundNumber = roundNumber,
		lockedIn = lockedIn,
		leadingRiteName = leadingRiteName,
		leadingRiteTitle = leadingRiteConfig.title,
		leadingRiteSummary = leadingRiteConfig.summary,
		leadingRiteVotes = voteCounts[leadingRiteName] or 0,
		selectedRiteName = activeSelectedRiteName,
		selectedRiteTitle = if selectedRiteConfig ~= nil then selectedRiteConfig.title else "",
		selectedRiteSummary = if selectedRiteConfig ~= nil then selectedRiteConfig.summary else "",
		votedRiteName = votedRiteName,
		votedRiteTitle = if votedRiteConfig ~= nil then votedRiteConfig.title else "",
		votedRiteSummary = if votedRiteConfig ~= nil then votedRiteConfig.summary else "",
		rites = table.freeze(riteSnapshots),
	})
end

local function broadcastRiteState()
	for _, player in ipairs(Players:GetPlayers()) do
		getRemoteEvent():FireClient(
			player,
			buildRiteState(
				riteState.phaseName,
				riteState.roundNumber,
				riteState.lockedIn,
				riteState.selectedRiteName,
				player
			)
		)
	end
end

local function pushRiteState(player: Player)
	getRemoteEvent():FireClient(
		player,
		buildRiteState(
			riteState.phaseName,
			riteState.roundNumber,
			riteState.lockedIn,
			riteState.selectedRiteName,
			player
		)
	)
end

local function findRiteSnapshot(riteName: string)
	for _, snapshot in ipairs(riteState.rites) do
		if snapshot.name == riteName then
			return snapshot
		end
	end

	return nil
end

local function updateShrineVisuals(riteName: string)
	local shrineEntry = shrineEntriesByName[riteName]

	if shrineEntry == nil then
		return
	end

	local riteConfig = getRiteConfig(riteName)
	local snapshot = findRiteSnapshot(riteName)
	local voteCount = if snapshot ~= nil then snapshot.votes else 0
	local isLeading = if snapshot ~= nil then snapshot.isLeading else false
	local isSelected = if snapshot ~= nil then snapshot.isSelected else false
	local brightnessBoost = if isSelected then 1.5 elseif isLeading then 0.8 else 0

	shrineEntry.part.Size = Vector3.new(
		3.6 + (if isLeading then 0.35 else 0) + (if isSelected then 0.55 else 0),
		7 + math.min(voteCount, 4) * 0.4 + (if isSelected then 0.8 else 0),
		3.6 + (if isLeading then 0.35 else 0) + (if isSelected then 0.55 else 0)
	)
	shrineEntry.part.Color = riteConfig.color
	shrineEntry.part.Material = if isSelected
		then Enum.Material.Neon
		elseif isLeading then Enum.Material.SmoothPlastic
		else Enum.Material.Slate

	shrineEntry.light.Color = riteConfig.color
	shrineEntry.light.Brightness = 1 + brightnessBoost + (voteCount * 0.2)
	shrineEntry.light.Range = 10 + (voteCount * 2) + (if isSelected then 6 else 0)

	shrineEntry.label.Text = string.format(
		"%s\n%s\nHold to vote | %d vote%s",
		riteConfig.title,
		riteConfig.summary,
		voteCount,
		if voteCount == 1 then "" else "s"
	)
	shrineEntry.label.TextColor3 = if isSelected then Color3.fromRGB(255, 248, 232) else riteConfig.color

	shrineEntry.prompt.ActionText = string.format("Bind %s", riteConfig.title)
	shrineEntry.prompt.ObjectText = string.format(
		"%s | Hold to vote | %d vote%s",
		riteConfig.summary,
		voteCount,
		if voteCount == 1 then "" else "s"
	)
	shrineEntry.prompt.Enabled = riteState.phaseName == "DayPrep" and not riteState.lockedIn
end

local function refreshShrineVisuals()
	for _, riteName in ipairs(getRiteOrder()) do
		updateShrineVisuals(riteName)
	end
end

local function applyRiteState(nextState)
	setRiteState(nextState)
	refreshShrineVisuals()
	broadcastRiteState()
end

local function handleVote(player: Player, riteName: string)
	if riteState.phaseName ~= "DayPrep" or riteState.lockedIn then
		return
	end

	if getRiteConfig(riteName) == nil then
		return
	end

	votesByUserId[player.UserId] = riteName
	applyRiteState(buildRiteState("DayPrep", riteState.roundNumber, false, "", nil))
end

local function buildShrine(riteName: string, index: number, totalShrines: number)
	local folder = getShrineFolder()
	local riteConfig = getRiteConfig(riteName)
	local existingShrine = folder:FindFirstChild(riteName)
	local shrinePart = existingShrine

	if shrinePart == nil then
		shrinePart = Instance.new("Part")
		shrinePart.Name = riteName
		shrinePart.Anchored = true
		shrinePart.Parent = folder
	end

	shrinePart.Size = Vector3.new(3.6, 7, 3.6)
	shrinePart.Position = buildShrinePosition(index, totalShrines)
	shrinePart.CFrame = CFrame.lookAt(shrinePart.Position, objectiveService.getCampCenter())
	shrinePart.TopSurface = Enum.SurfaceType.Smooth
	shrinePart.BottomSurface = Enum.SurfaceType.Smooth

	local prompt = shrinePart:FindFirstChild("VotePrompt")
	if prompt == nil then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "VotePrompt"
		prompt.HoldDuration = 0.55
		prompt.MaxActivationDistance = 12
		prompt.Parent = shrinePart

		prompt.Triggered:Connect(function(player)
			handleVote(player, riteName)
		end)
	end

	local light = shrinePart:FindFirstChild("ShrineLight")
	if light == nil then
		light = Instance.new("PointLight")
		light.Name = "ShrineLight"
		light.Parent = shrinePart
	end

	local billboard = shrinePart:FindFirstChild("RiteBillboard")
	if billboard == nil then
		billboard = Instance.new("BillboardGui")
		billboard.Name = "RiteBillboard"
		billboard.Size = UDim2.fromOffset(188, 86)
		billboard.StudsOffset = Vector3.new(0, 6.2, 0)
		billboard.AlwaysOnTop = true
		billboard.Parent = shrinePart
	end

	local label = billboard:FindFirstChild("RiteLabel")
	if label == nil then
		label = Instance.new("TextLabel")
		label.Name = "RiteLabel"
		label.Size = UDim2.fromScale(1, 1)
		label.BackgroundTransparency = 1
		label.Font = Enum.Font.GothamBold
		label.TextSize = 13
		label.TextWrapped = true
		label.Parent = billboard
	end

	label.TextStrokeTransparency = 0.4
	label.Text = string.format("%s\n%s\nHold to vote | 0 votes", riteConfig.title, riteConfig.summary)

	shrineEntriesByName[riteName] = {
		part = shrinePart,
		prompt = prompt,
		light = light,
		label = label,
	}

	updateShrineVisuals(riteName)
end

function RiteService.initialize(dependencies)
	objectiveService = dependencies.objectiveService

	for index, riteName in ipairs(getRiteOrder()) do
		buildShrine(riteName, index, #getRiteOrder())
	end

	Players.PlayerRemoving:Connect(function(player)
		if votesByUserId[player.UserId] == nil then
			return
		end

		votesByUserId[player.UserId] = nil

		if riteState.phaseName == "DayPrep" and not riteState.lockedIn then
			applyRiteState(buildRiteState("DayPrep", riteState.roundNumber, false, "", nil))
		end
	end)

	applyRiteState(buildRiteState("Lobby", 0, false, "", nil))
end

function RiteService.startDayPhase(roundNumber: number)
	votesByUserId = {}
	applyRiteState(buildRiteState("DayPrep", roundNumber, false, "", nil))

	return riteState
end

function RiteService.startNightPhase(roundNumber: number)
	local selectedRiteName = determineLeadingRiteName(roundNumber, getVoteCounts())
	applyRiteState(buildRiteState("NightSurvival", roundNumber, true, selectedRiteName, nil))

	return riteState
end

function RiteService.finishRound(roundNumber: number)
	local selectedRiteName = riteState.selectedRiteName

	if selectedRiteName == "" then
		selectedRiteName = determineLeadingRiteName(roundNumber, getVoteCounts())
	end

	applyRiteState(buildRiteState("Results", roundNumber, true, selectedRiteName, nil))

	return riteState
end

function RiteService.getNightModifiers()
	local selectedRiteName = riteState.selectedRiteName

	if selectedRiteName == "" then
		return EMPTY_MODIFIERS
	end

	local riteConfig = getRiteConfig(selectedRiteName)

	if riteConfig == nil then
		return EMPTY_MODIFIERS
	end

	return riteConfig.modifiers
end

function RiteService.getSelectedRiteName(): string
	return riteState.selectedRiteName
end

function RiteService.getPlayerVotedRiteName(player: Player): string
	return getVotedRiteNameForUserId(player.UserId)
end

function RiteService.getRiteTitle(riteName: string): string
	local riteConfig = getRiteConfig(riteName)

	if riteConfig == nil then
		return ""
	end

	return riteConfig.title
end

function RiteService.getSuggestedShrinePosition(): Vector3
	if riteState.leadingRiteName ~= "" and shrineEntriesByName[riteState.leadingRiteName] ~= nil then
		return shrineEntriesByName[riteState.leadingRiteName].part.Position
	end

	local firstRiteName = getRiteOrder()[1]
	local firstRiteEntry = if firstRiteName ~= nil then shrineEntriesByName[firstRiteName] else nil

	if firstRiteEntry ~= nil then
		return firstRiteEntry.part.Position
	end

	return objectiveService.getCampCenter()
end

function RiteService.getState()
	return riteState
end

function RiteService.syncPlayer(player: Player)
	pushRiteState(player)
end

return RiteService
]]></ProtectedString>
						<string name="ScriptGuid">{AA8271E5-9A86-4C3F-A775-E0A20F12242A}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">RiteService</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">4be6c94ec416c0c409e3a308000003af</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="24">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = ReplicatedStorage:WaitForChild("Shared")
local GameConfig = require(Shared:WaitForChild("GameConfig"))
local RemoteNames = require(Shared:WaitForChild("RemoteNames"))

local RoleService = {}

local EMPTY_MODIFIERS = table.freeze({
	extraSuppliesPerCrate = 0,
	nearbyHelperSupplyBonus = 0,
	repairAmountBonus = 0,
	repairCostReduction = 0,
	reinforceCostReduction = 0,
	chargeAmountBonus = 0,
	chargeCostReduction = 0,
	overchargeCostReduction = 0,
	meleeDamageBonus = 0,
	pulseCooldownDelta = 0,
	pulseDamageBonus = 0,
})

local objectiveService = nil
local dutyService = nil
local roleFolder = nil
local roleEntriesByName = {}
local selectedRolesByUserId = {}
local roleState = table.freeze({
	phaseName = "Lobby",
	roundNumber = 0,
	lockedIn = false,
	teamCoverageCount = 0,
	selectedRoleName = "",
	selectedRoleTitle = "",
	selectedRoleSummary = "",
	roles = table.freeze({}),
})

local function getRemoteEvent(): RemoteEvent
	local remoteFolder = ReplicatedStorage:WaitForChild(RemoteNames.Folder)
	return remoteFolder:WaitForChild(RemoteNames.RoleStateChanged) :: RemoteEvent
end

local function setRoleState(nextState)
	roleState = table.freeze(nextState)
end

local function getRoleOrder()
	return GameConfig.RoleTuning.Order
end

local function getRoleConfig(roleName: string)
	return GameConfig.RoleTuning.Roles[roleName]
end

local function getSelectedRoleNameForUserId(userId: number): string
	local selectedRoleName = selectedRolesByUserId[userId]

	if type(selectedRoleName) ~= "string" then
		return ""
	end

	if getRoleConfig(selectedRoleName) == nil then
		return ""
	end

	return selectedRoleName
end

local function getRoleCounts()
	local roleCounts = {}

	for _, roleName in ipairs(getRoleOrder()) do
		roleCounts[roleName] = 0
	end

	for userId, roleName in pairs(selectedRolesByUserId) do
		if Players:GetPlayerByUserId(userId) ~= nil and roleCounts[roleName] ~= nil then
			roleCounts[roleName] += 1
		end
	end

	return roleCounts
end

local function getTeamCoverageCount(roleCounts)
	local coverageCount = 0

	for _, roleName in ipairs(getRoleOrder()) do
		if (roleCounts[roleName] or 0) > 0 then
			coverageCount += 1
		end
	end

	return coverageCount
end

local function getRoleFolder()
	if roleFolder ~= nil and roleFolder.Parent ~= nil then
		return roleFolder
	end

	local runtimeFolder = objectiveService.getRuntimeFolder()
	local existingFolder = runtimeFolder:FindFirstChild("RoleStations")

	if existingFolder ~= nil then
		roleFolder = existingFolder
		return roleFolder
	end

	roleFolder = Instance.new("Folder")
	roleFolder.Name = "RoleStations"
	roleFolder.Parent = runtimeFolder

	return roleFolder
end

local function buildRolePosition(index: number, totalRoles: number): Vector3
	local angle = (math.pi / 2) + (((index - 1) / math.max(totalRoles, 1)) * math.pi * 2)
	local radius = GameConfig.RoleTuning.StationRadius

	return Vector3.new(math.cos(angle) * radius, 3.5, math.sin(angle) * radius)
end

local function buildRolePayloadForPlayer(player: Player, phaseName: string, roundNumber: number, lockedIn: boolean)
	local roleCounts = getRoleCounts()
	local selectedRoleName = getSelectedRoleNameForUserId(player.UserId)
	local selectedRoleConfig = if selectedRoleName ~= "" then getRoleConfig(selectedRoleName) else nil
	local roleSnapshots = {}

	for _, roleName in ipairs(getRoleOrder()) do
		local roleConfig = getRoleConfig(roleName)
		table.insert(
			roleSnapshots,
			table.freeze({
				name = roleName,
				title = roleConfig.title,
				summary = roleConfig.summary,
				assignedPlayers = roleCounts[roleName] or 0,
				isSelected = roleName == selectedRoleName,
			})
		)
	end

	return table.freeze({
		phaseName = phaseName,
		roundNumber = roundNumber,
		lockedIn = lockedIn,
		teamCoverageCount = getTeamCoverageCount(roleCounts),
		selectedRoleName = selectedRoleName,
		selectedRoleTitle = if selectedRoleConfig ~= nil then selectedRoleConfig.title else "",
		selectedRoleSummary = if selectedRoleConfig ~= nil then selectedRoleConfig.summary else "",
		roles = table.freeze(roleSnapshots),
	})
end

local function findRoleSnapshot(roleName: string)
	for _, snapshot in ipairs(roleState.roles) do
		if snapshot.name == roleName then
			return snapshot
		end
	end

	return nil
end

local function updateRoleStationVisuals(roleName: string)
	local roleEntry = roleEntriesByName[roleName]

	if roleEntry == nil then
		return
	end

	local roleConfig = getRoleConfig(roleName)
	local snapshot = findRoleSnapshot(roleName)
	local assignedPlayers = if snapshot ~= nil then snapshot.assignedPlayers else 0
	local isPopular = assignedPlayers > 0

	roleEntry.part.Size = Vector3.new(
		3.8 + math.min(assignedPlayers, 2) * 0.25,
		5.5 + math.min(assignedPlayers, 3) * 0.35,
		3.8 + math.min(assignedPlayers, 2) * 0.25
	)
	roleEntry.part.Color = roleConfig.color
	roleEntry.part.Material = if isPopular then Enum.Material.SmoothPlastic else Enum.Material.Slate

	roleEntry.light.Color = roleConfig.color
	roleEntry.light.Brightness = 0.8 + (assignedPlayers * 0.25)
	roleEntry.light.Range = 10 + (assignedPlayers * 2)

	roleEntry.label.Text = string.format(
		"%s\n%s\nHold to choose | %d player%s",
		roleConfig.title,
		roleConfig.summary,
		assignedPlayers,
		if assignedPlayers == 1 then "" else "s"
	)
	roleEntry.label.TextColor3 = roleConfig.color

	roleEntry.prompt.ActionText = string.format("Choose %s", roleConfig.title)
	roleEntry.prompt.ObjectText = string.format(
		"%s | %d player%s on this role",
		roleConfig.summary,
		assignedPlayers,
		if assignedPlayers == 1 then "" else "s"
	)
	roleEntry.prompt.Enabled = roleState.phaseName == "DayPrep" and not roleState.lockedIn
end

local function refreshRoleStationVisuals()
	for _, roleName in ipairs(getRoleOrder()) do
		updateRoleStationVisuals(roleName)
	end
end

local function broadcastRoleState(phaseName: string, roundNumber: number, lockedIn: boolean)
	local firstPlayer = Players:GetPlayers()[1]

	if firstPlayer ~= nil then
		setRoleState(buildRolePayloadForPlayer(firstPlayer, phaseName, roundNumber, lockedIn))
	else
		setRoleState(table.freeze({
			phaseName = phaseName,
			roundNumber = roundNumber,
			lockedIn = lockedIn,
			teamCoverageCount = 0,
			selectedRoleName = "",
			selectedRoleTitle = "",
			selectedRoleSummary = "",
			roles = table.freeze({}),
		}))
	end

	refreshRoleStationVisuals()

	for _, player in ipairs(Players:GetPlayers()) do
		getRemoteEvent():FireClient(player, buildRolePayloadForPlayer(player, phaseName, roundNumber, lockedIn))
	end
end

local function handleRoleSelection(player: Player, roleName: string)
	if roleState.phaseName ~= "DayPrep" or roleState.lockedIn then
		return
	end

	if getRoleConfig(roleName) == nil then
		return
	end

	selectedRolesByUserId[player.UserId] = roleName
	broadcastRoleState("DayPrep", roleState.roundNumber, false)

	if dutyService ~= nil then
		dutyService.handleRoleAssignmentsChanged()
	end
end

local function buildRoleStation(roleName: string, index: number, totalRoles: number)
	local folder = getRoleFolder()
	local roleConfig = getRoleConfig(roleName)
	local existingStation = folder:FindFirstChild(roleName)
	local stationPart = existingStation

	if stationPart == nil then
		stationPart = Instance.new("Part")
		stationPart.Name = roleName
		stationPart.Anchored = true
		stationPart.Parent = folder
	end

	stationPart.Size = Vector3.new(3.8, 5.5, 3.8)
	stationPart.Position = buildRolePosition(index, totalRoles)
	stationPart.CFrame = CFrame.lookAt(stationPart.Position, objectiveService.getCampCenter())
	stationPart.TopSurface = Enum.SurfaceType.Smooth
	stationPart.BottomSurface = Enum.SurfaceType.Smooth

	local prompt = stationPart:FindFirstChild("RolePrompt")
	if prompt == nil then
		prompt = Instance.new("ProximityPrompt")
		prompt.Name = "RolePrompt"
		prompt.HoldDuration = 0.45
		prompt.MaxActivationDistance = 12
		prompt.Parent = stationPart

		prompt.Triggered:Connect(function(player)
			handleRoleSelection(player, roleName)
		end)
	end

	local light = stationPart:FindFirstChild("RoleLight")
	if light == nil then
		light = Instance.new("PointLight")
		light.Name = "RoleLight"
		light.Parent = stationPart
	end

	local billboard = stationPart:FindFirstChild("RoleBillboard")
	if billboard == nil then
		billboard = Instance.new("BillboardGui")
		billboard.Name = "RoleBillboard"
		billboard.Size = UDim2.fromOffset(188, 82)
		billboard.StudsOffset = Vector3.new(0, 5.6, 0)
		billboard.AlwaysOnTop = true
		billboard.Parent = stationPart
	end

	local label = billboard:FindFirstChild("RoleLabel")
	if label == nil then
		label = Instance.new("TextLabel")
		label.Name = "RoleLabel"
		label.Size = UDim2.fromScale(1, 1)
		label.BackgroundTransparency = 1
		label.Font = Enum.Font.GothamBold
		label.TextSize = 13
		label.TextWrapped = true
		label.Parent = billboard
	end

	label.TextStrokeTransparency = 0.4
	label.Text = string.format("%s\n%s\nHold to choose | 0 players", roleConfig.title, roleConfig.summary)

	roleEntriesByName[roleName] = {
		part = stationPart,
		prompt = prompt,
		light = light,
		label = label,
	}

	updateRoleStationVisuals(roleName)
end

function RoleService.initialize(dependencies)
	objectiveService = dependencies.objectiveService
	dutyService = dependencies.dutyService

	for index, roleName in ipairs(getRoleOrder()) do
		buildRoleStation(roleName, index, #getRoleOrder())
	end

	Players.PlayerRemoving:Connect(function(player)
		if selectedRolesByUserId[player.UserId] == nil then
			return
		end

		selectedRolesByUserId[player.UserId] = nil
		broadcastRoleState(roleState.phaseName, roleState.roundNumber, roleState.lockedIn)

		if dutyService ~= nil then
			dutyService.handleRoleAssignmentsChanged()
		end
	end)

	broadcastRoleState("Lobby", 0, false)
end

function RoleService.startDayPhase(roundNumber: number)
	broadcastRoleState("DayPrep", roundNumber, false)

	return roleState
end

function RoleService.startNightPhase(roundNumber: number)
	broadcastRoleState("NightSurvival", roundNumber, true)

	return roleState
end

function RoleService.finishRound(roundNumber: number)
	broadcastRoleState("Results", roundNumber, true)

	return roleState
end

function RoleService.getSelectedRoleName(player: Player): string
	return getSelectedRoleNameForUserId(player.UserId)
end

function RoleService.getRoleModifiersForPlayer(player: Player)
	local selectedRoleName = RoleService.getSelectedRoleName(player)

	if selectedRoleName == "" then
		return EMPTY_MODIFIERS
	end

	local roleConfig = getRoleConfig(selectedRoleName)

	if roleConfig == nil then
		return EMPTY_MODIFIERS
	end

	return roleConfig.modifiers
end

function RoleService.getRoleTitle(roleName: string): string
	local roleConfig = getRoleConfig(roleName)

	if roleConfig == nil then
		return ""
	end

	return roleConfig.title
end

function RoleService.getTeamCoverageCount(): number
	return getTeamCoverageCount(getRoleCounts())
end

function RoleService.getSuggestedStationPosition(): Vector3
	local roleCounts = getRoleCounts()

	for _, roleName in ipairs(getRoleOrder()) do
		if (roleCounts[roleName] or 0) == 0 then
			local roleEntry = roleEntriesByName[roleName]

			if roleEntry ~= nil then
				return roleEntry.part.Position
			end
		end
	end

	local firstRoleName = getRoleOrder()[1]
	local firstRoleEntry = if firstRoleName ~= nil then roleEntriesByName[firstRoleName] else nil

	if firstRoleEntry ~= nil then
		return firstRoleEntry.part.Position
	end

	return objectiveService.getCampCenter()
end

function RoleService.getState()
	return roleState
end

function RoleService.syncPlayer(player: Player)
	getRemoteEvent():FireClient(
		player,
		buildRolePayloadForPlayer(player, roleState.phaseName, roleState.roundNumber, roleState.lockedIn)
	)
end

return RoleService
]]></ProtectedString>
						<string name="ScriptGuid">{204A918D-B773-43AF-ADD1-E171B5DB9B0A}</string>
						<BinaryString name="AttributesSerialize"></BinaryString>
						<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
						<bool name="DefinesCapabilities">false</bool>
						<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
						<string name="Name">RoleService</string>
						<int64 name="SourceAssetId">-1</int64>
						<BinaryString name="Tags"></BinaryString>
						<UniqueId name="UniqueId">4be6c94ec416c0c409e3a308000003b0</UniqueId>
					</Properties>
				</Item>
				<Item class="ModuleScript" referent="25">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Shared = ReplicatedStorage:WaitForChild("Shared")
local GameConfig = require(Shared:WaitForChild("GameConfig"))
local RemoteNames = require(Shared:WaitForChild("RemoteNames"))

local RoundService = {}

local currentState = table.freeze({
	isRunning = false,
	roundNumber = 0,
	phaseName = "Lobby",
})

local function setState(nextState)
	currentState = table.freeze(nextState)
end

local function getRemoteFolder()
	return ReplicatedStorage:WaitForChild(RemoteNames.Folder)
end

local function getPhaseChangedEvent(): RemoteEvent
	local remoteFolder = getRemoteFolder()
	return remoteFolder:WaitForChild(RemoteNames.PhaseChanged) :: RemoteEvent
end

local function getRewardPreviewEvent(): RemoteEvent
	local remoteFolder = getRemoteFolder()
	return remoteFolder:WaitForChild(RemoteNames.RewardPreview) :: RemoteEvent
end

local function broadcastPhase(phaseName: string, roundNumber: number, durationSeconds: number, metadata)
	local payload = table.freeze({
		name = phaseName,
		roundNumber = roundNumber,
		durationSeconds = durationSeconds,
		startedAtUnix = os.time(),
		metadata = metadata or {},
	})

	setState({
		isRunning = true,
		roundNumber = roundNumber,
		phaseName = phaseName,
		lastPayload = payload,
	})

	getPhaseChangedEvent():FireAllClients(payload)
end

local function waitForNightToResolve(durationSeconds: number, threatService)
	local startedAt = os.clock()

	while (os.clock() - startedAt) < durationSeconds do
		if threatService.hasNightEnded() then
			break
		end

		task.wait(0.5)
	end
end

local function buildRoundPlan(roundNumber: number, playerCount: number, spawnDirector)
	local tutorialMode = spawnDirector.isGuidedRound(roundNumber)
	local tutorialTuning = GameConfig.TutorialTuning
	local nightPlan = spawnDirector.buildNightPlan(roundNumber, playerCount)

	return table.freeze({
		tutorialMode = tutorialMode,
		tutorialTitle = if tutorialMode then tutorialTuning.Title else "",
		tutorialSummary = if tutorialMode then tutorialTuning.Summary else "",
		dayPrepDuration = if tutorialMode then tutorialTuning.DayPrepDuration else GameConfig.PhaseDurations.DayPrep,
		nightSurvivalDuration = if tutorialMode
			then tutorialTuning.NightSurvivalDuration
			else GameConfig.PhaseDurations.NightSurvival,
		targetBarricadeLaneName = if tutorialMode then tutorialTuning.TargetBarricadeLaneName else "",
		targetTowerLaneName = if tutorialMode then tutorialTuning.TargetTowerLaneName else "",
		allowedLaneNames = if tutorialMode then tutorialTuning.AllowedLaneNames else table.freeze({}),
		objectiveOptions = if tutorialMode
			then table.freeze({
				resourceNodeCount = tutorialTuning.ResourceNodes,
			})
			else nil,
		defenseOptions = if tutorialMode
			then table.freeze({
				tutorialMode = true,
			})
			else nil,
		nightPlan = nightPlan,
	})
end

local function buildRoundOutcome(
	roundNumber: number,
	playerCount: number,
	objectiveState,
	defenseState,
	threatState,
	roleState,
	rescueState
)
	local lanternCharge = if objectiveState ~= nil then objectiveState.lanternCharge else 0
	local objectiveProgress = 0
	local defenseBonus = 0
	local tacticalBonus = 0
	local lanternHealthRatio = 1
	local barricadesStanding = 0
	local fortificationLevel = 0
	local overchargeLevel = 0
	local suppliesCollected = 0
	local suppliesSpent = 0
	local teamCoverageCount = 0
	local concordLanes = 0
	local revivesCompleted = 0
	local bleedouts = 0
	local alivePlayers = math.max(1, math.floor(playerCount * 0.75))
	local nightFailed = if threatState ~= nil then threatState.nightFailed else false
	local nightCleared = if threatState ~= nil then threatState.nightCleared else false

	if objectiveState ~= nil and objectiveState.resourcesRequired > 0 then
		objectiveProgress =
			math.clamp(math.ceil((objectiveState.resourcesCollected / objectiveState.resourcesRequired) * 2), 0, 2)
		suppliesCollected = objectiveState.totalSuppliesCollected or 0
		suppliesSpent = objectiveState.spentSupplies or 0
	end

	if defenseState ~= nil and defenseState.totalBarricades > 0 then
		barricadesStanding = defenseState.healthyBarricades
		fortificationLevel = defenseState.totalFortificationLevel or 0
		overchargeLevel = defenseState.totalOverchargeLevel or 0
		concordLanes = defenseState.totalConcordLanes or 0

		if defenseState.healthyBarricades == defenseState.totalBarricades then
			defenseBonus = 2
		elseif defenseState.healthyBarricades >= math.ceil(defenseState.totalBarricades / 2) then
			defenseBonus = 1
		end
	end

	if suppliesCollected > 0 and suppliesSpent >= math.ceil(suppliesCollected * 0.5) then
		tacticalBonus += 1
	end

	if fortificationLevel > 0 and overchargeLevel > 0 then
		tacticalBonus += 1
	end

	if roleState ~= nil then
		teamCoverageCount = roleState.teamCoverageCount or 0
	end

	if concordLanes > 0 then
		tacticalBonus += 1
	end

	if threatState ~= nil and threatState.lanternMaxHealth > 0 then
		lanternHealthRatio = threatState.lanternHealth / threatState.lanternMaxHealth
		if nightFailed then
			alivePlayers = math.max(0, math.floor(playerCount * 0.35))
		else
			alivePlayers = math.max(1, math.floor(playerCount * (0.55 + (lanternHealthRatio * 0.35))))
		end
	end

	if rescueState ~= nil then
		revivesCompleted = rescueState.totalRevives or 0
		bleedouts = rescueState.totalBleedouts or 0
	end

	return table.freeze({
		nightNumber = roundNumber,
		alivePlayers = alivePlayers,
		totalPlayers = playerCount,
		lanternCharge = lanternCharge,
		objectivesCompleted = math.clamp(objectiveProgress + defenseBonus + tacticalBonus, 0, 6),
		lanternHealthRatio = lanternHealthRatio,
		barricadesStanding = barricadesStanding,
		fortificationLevel = fortificationLevel,
		overchargeLevel = overchargeLevel,
		suppliesCollected = suppliesCollected,
		suppliesSpent = suppliesSpent,
		teamCoverageCount = teamCoverageCount,
		concordLanes = concordLanes,
		revivesCompleted = revivesCompleted,
		bleedouts = bleedouts,
		nightFailed = nightFailed,
		nightCleared = nightCleared,
	})
end

local function findDutySnapshot(dutyState, roleName: string)
	if dutyState == nil then
		return nil
	end

	for _, dutySnapshot in ipairs(dutyState.duties or {}) do
		if dutySnapshot.name == roleName then
			return dutySnapshot
		end
	end

	return nil
end

local function buildPlayerMasterySummary(player: Player, dependencies, context)
	local masteryTuning = GameConfig.MasteryTuning
	local selectedRoleName = dependencies.roleService.getSelectedRoleName(player)
	local selectedRiteName = dependencies.riteService.getSelectedRiteName()
	local votedRiteName = dependencies.riteService.getPlayerVotedRiteName(player)
	local roleSummary = nil
	local riteSummary = nil

	if selectedRoleName ~= "" then
		local roleExperience = masteryTuning.RoleBaseExperience
		local dutySnapshot = findDutySnapshot(context.dutyState, selectedRoleName)

		if dutySnapshot ~= nil and dutySnapshot.completed then
			roleExperience += masteryTuning.RoleDutyCompletedBonus
		end

		if (context.roleState.teamCoverageCount or 0) >= #GameConfig.RoleTuning.Order then
			roleExperience += masteryTuning.RoleCoverageBonus
		end

		if context.roundOutcome.nightCleared then
			roleExperience += masteryTuning.RoleClearBonus
		end

		if (context.roundOutcome.concordLanes or 0) > 0 then
			roleExperience += masteryTuning.RoleConcordBonus
		end

		roleSummary = table.freeze({
			name = selectedRoleName,
			title = dependencies.roleService.getRoleTitle(selectedRoleName),
			experience = roleExperience,
		})
	end

	local targetRiteName = if votedRiteName ~= "" then votedRiteName else selectedRiteName

	if targetRiteName ~= "" then
		local riteExperience = masteryTuning.RiteBaseExperience

		if votedRiteName ~= "" and votedRiteName == selectedRiteName then
			riteExperience += masteryTuning.RiteAlignedVoteBonus
		end

		if context.roundOutcome.nightCleared then
			riteExperience += masteryTuning.RiteClearBonus
		end

		riteSummary = table.freeze({
			name = targetRiteName,
			title = dependencies.riteService.getRiteTitle(targetRiteName),
			experience = riteExperience,
		})
	end

	return table.freeze({
		role = roleSummary,
		rite = riteSummary,
	})
end

function RoundService.getState()
	return currentState
end

function RoundService.syncPlayer(player: Player)
	if currentState.lastPayload == nil then
		return
	end

	getPhaseChangedEvent():FireClient(player, currentState.lastPayload)
end

function RoundService.start(dependencies)
	if currentState.isRunning then
		return
	end

	setState({
		isRunning = true,
		roundNumber = 0,
		phaseName = "Lobby",
	})

	task.spawn(function()
		local roundNumber = 0

		while true do
			local playerCount = #Players:GetPlayers()

			if playerCount < GameConfig.MinimumPlayers then
				broadcastPhase("Lobby", roundNumber, GameConfig.PhaseDurations.Lobby, {
					waitingForPlayers = true,
					playersNeeded = GameConfig.MinimumPlayers - playerCount,
				})
				task.wait(5)
			else
				roundNumber = roundNumber + 1
				local roundPlan = buildRoundPlan(roundNumber, playerCount, dependencies.spawnDirector)

				broadcastPhase("Lobby", roundNumber, GameConfig.PhaseDurations.Lobby, {
					waitingForPlayers = false,
					tutorialMode = roundPlan.tutorialMode,
					tutorialTitle = roundPlan.tutorialTitle,
				})
				task.wait(GameConfig.PhaseDurations.Lobby)

				local dayDefenseState = dependencies.defenseService.startDayPhase(roundNumber, roundPlan.defenseOptions)
				local dayObjectiveState =
					dependencies.objectiveService.startDayPhase(roundNumber, playerCount, roundPlan.objectiveOptions)
				local dayDutyState = dependencies.dutyService.startDayPhase(roundNumber, playerCount)
				local dayEchoState = dependencies.echoService.startDayPhase(roundNumber, playerCount)
				local dayRoleState = dependencies.roleService.startDayPhase(roundNumber)
				local dayRiteState = dependencies.riteService.startDayPhase(roundNumber)
				dependencies.riteFocusService.startDayPhase(roundNumber)
				dependencies.signalService.startDayPhase(roundNumber)
				broadcastPhase("DayPrep", roundNumber, roundPlan.dayPrepDuration, {
					resourceNodes = dayObjectiveState.resourcesRequired,
					interactionPrompt = if roundPlan.tutorialMode
						then string.format(
							"Guided %s: collect fuel, choose a role, repair %s, charge %s, and vote.",
							roundPlan.tutorialTitle,
							roundPlan.targetBarricadeLaneName,
							roundPlan.targetTowerLaneName
						)
						else "Collect fuel, choose roles, shore up lanes, and choose a lantern rite.",
					activeBarricades = dayDefenseState.healthyBarricades,
					averageTowerEnergy = dayDefenseState.averageTowerEnergy,
					teamCoverageCount = dayRoleState.teamCoverageCount,
					leadingRiteTitle = dayRiteState.leadingRiteTitle,
					leadingRiteSummary = dayRiteState.leadingRiteSummary,
					tutorialMode = roundPlan.tutorialMode,
					tutorialTitle = roundPlan.tutorialTitle,
					tutorialSummary = roundPlan.tutorialSummary,
					targetBarricadeLaneName = roundPlan.targetBarricadeLaneName,
					targetTowerLaneName = roundPlan.targetTowerLaneName,
					completedDutyCount = dayDutyState.completedDutyCount,
					activeDutyCount = dayDutyState.activeDutyCount,
					unlockedBoonCount = dayEchoState.unlockedBoonCount,
				})
				task.wait(roundPlan.dayPrepDuration)

				local nightDutyState = dependencies.dutyService.startNightPhase(roundNumber)
				local nightEchoState = dependencies.echoService.startNightPhase(roundNumber)
				local nightRoleState = dependencies.roleService.startNightPhase(roundNumber)
				local nightRiteState = dependencies.riteService.startNightPhase(roundNumber)
				dependencies.riteFocusService.startNightPhase(roundNumber)
				local nightRescueState = dependencies.rescueService.startNightPhase(roundNumber)
				local nightDefenseState = dependencies.defenseService.startNightPhase(roundNumber)
				dependencies.signalService.startNightPhase(roundNumber)
				local nightObjectiveState = dependencies.objectiveService.startNightPhase(roundNumber)
				local nightPlan = roundPlan.nightPlan
				local enrichedNightPlan = table.freeze({
					tutorialMode = nightPlan.tutorialMode == true,
					tutorialTitle = nightPlan.tutorialTitle,
					tutorialSummary = nightPlan.tutorialSummary,
					threatRate = nightPlan.threatRate,
					spawnIntervalSeconds = nightPlan.spawnIntervalSeconds,
					maxSimultaneousThreats = nightPlan.maxSimultaneousThreats,
					eliteChance = nightPlan.eliteChance,
					warningLeadSeconds = nightPlan.warningLeadSeconds,
					allowedLaneNames = nightPlan.allowedLaneNames,
					forcedLaneSequence = nightPlan.forcedLaneSequence,
					threatSequence = nightPlan.threatSequence,
					desiredSpawnCount = nightPlan.desiredSpawnCount,
					waveLabelOverride = nightPlan.waveLabelOverride,
					lanternCharge = nightObjectiveState.lanternCharge,
					healthyBarricades = nightDefenseState.healthyBarricades,
				})
				local initialThreatState = dependencies.threatService.startNightPhase(
					roundNumber,
					roundPlan.nightSurvivalDuration,
					enrichedNightPlan,
					nightObjectiveState
				)
				broadcastPhase("NightSurvival", roundNumber, roundPlan.nightSurvivalDuration, {
					threatRate = enrichedNightPlan.threatRate,
					spawnIntervalSeconds = enrichedNightPlan.spawnIntervalSeconds,
					maxSimultaneousThreats = enrichedNightPlan.maxSimultaneousThreats,
					eliteChance = enrichedNightPlan.eliteChance,
					lanternCharge = nightObjectiveState.lanternCharge,
					lanternHealth = initialThreatState.lanternHealth,
					healthyBarricades = nightDefenseState.healthyBarricades,
					teamCoverageCount = nightRoleState.teamCoverageCount,
					riteTitle = nightRiteState.selectedRiteTitle,
					riteSummary = nightRiteState.selectedRiteSummary,
					activeDownedCount = nightRescueState.activeDownedCount,
					tutorialMode = roundPlan.tutorialMode,
					tutorialTitle = roundPlan.tutorialTitle,
					tutorialSummary = roundPlan.tutorialSummary,
					allowedLaneNames = roundPlan.allowedLaneNames,
					targetBarricadeLaneName = roundPlan.targetBarricadeLaneName,
					targetTowerLaneName = roundPlan.targetTowerLaneName,
					completedDutyCount = nightDutyState.completedDutyCount,
					activeDutyCount = nightDutyState.activeDutyCount,
					unlockedBoonCount = nightEchoState.unlockedBoonCount,
				})
				waitForNightToResolve(roundPlan.nightSurvivalDuration, dependencies.threatService)

				local finishedThreatState = dependencies.threatService.finishNightPhase(roundNumber)
				local finishedRescueState = dependencies.rescueService.finishRound(roundNumber)
				local finishedDutyState = dependencies.dutyService.finishRound(roundNumber)
				local finishedRoleState = dependencies.roleService.finishRound(roundNumber)
				local finishedRiteState = dependencies.riteService.finishRound(roundNumber)
				dependencies.riteFocusService.finishRound(roundNumber)
				local finishedDefenseState = dependencies.defenseService.finishRound(roundNumber)
				dependencies.signalService.finishRound(roundNumber)
				local finishedObjectiveState = dependencies.objectiveService.finishRound()
				local roundOutcome = buildRoundOutcome(
					roundNumber,
					playerCount,
					finishedObjectiveState,
					finishedDefenseState,
					finishedThreatState,
					finishedRoleState,
					finishedRescueState
				)
				local finishedEchoState = dependencies.echoService.finishRound(
					roundNumber,
					roundOutcome,
					finishedRoleState,
					finishedDefenseState
				)
				local rewards =
					dependencies.rewardService.calculateRewards(roundOutcome, finishedEchoState, finishedDutyState)

				for _, player in ipairs(Players:GetPlayers()) do
					local masterySummary = buildPlayerMasterySummary(player, dependencies, {
						dutyState = finishedDutyState,
						roleState = finishedRoleState,
						roundOutcome = roundOutcome,
					})
					dependencies.profileService.applyRoundRewards(player, rewards, roundOutcome, masterySummary)
				end

				getRewardPreviewEvent():FireAllClients(rewards)

				broadcastPhase("Results", roundNumber, GameConfig.PhaseDurations.Results, {
					outcome = roundOutcome,
					rewards = rewards,
					dutyState = finishedDutyState,
					echoState = finishedEchoState,
					roleState = finishedRoleState,
					riteState = finishedRiteState,
					threatState = finishedThreatState,
					rescueState = finishedRescueState,
					defenseState = finishedDefenseState,
				})
				task.wait(GameConfig.PhaseDurations.Results)
			end
		end
	end)
end

return RoundService
]]></ProtectedString>
